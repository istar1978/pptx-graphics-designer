    {"from": "hq_router", "to": "hq_fw1"},
    {"from": "hq_router", "to": "hq_fw2"},
    {"from": "hq_fw1", "to": "hq_core_sw"},
    {"from": "hq_fw2", "to": "hq_core_sw"},
    
    {"from": "hq_core_sw", "to": "hq_app_sw"},
    {"from": "hq_core_sw", "to": "hq_db_sw"},
    
    {"from": "hq_app_sw", "to": "hq_app1"},
    {"from": "hq_app_sw", "to": "hq_app2"},
    {"from": "hq_db_sw", "to": "hq_db1"},
    {"from": "hq_db_sw", "to": "hq_db2"},
    
    {"from": "hq_router", "to": "branch1_router", "label": "MPLS"},
    {"from": "branch1_router", "to": "branch1_sw"},
    {"from": "branch1_sw", "to": "branch1_pc1"},
    {"from": "branch1_sw", "to": "branch1_pc2"},
    
    {"from": "hq_router", "to": "branch2_router", "label": "MPLS"},
    {"from": "branch2_router", "to": "branch2_sw"},
    {"from": "branch2_sw", "to": "branch2_pc1"},
    {"from": "branch2_sw", "to": "branch2_pc2"}
  ]
}
