    {"id": "branch1_router", "type": "router", "x": 10.2, "y": 1.2, "width": 0.7, "height": 0.5, "label": "分支路由器"},
    {"id": "branch1_sw", "type": "switch", "x": 10.2, "y": 1.9, "width": 0.7, "height": 0.4, "label": "接入交换机"},
    {"id": "branch1_pc1", "type": "pc", "x": 9.8, "y": 2.4, "width": 0.4, "height": 0.3, "label": "办公 PC"},
    {"id": "branch1_pc2", "type": "pc", "x": 10.6, "y": 2.4, "width": 0.4, "height": 0.3, "label": "办公 PC"},
    
    {"id": "branch2_router", "type": "router", "x": 10.2, "y": 3.6, "width": 0.7, "height": 0.5, "label": "分支路由器"},
    {"id": "branch2_sw", "type": "switch", "x": 10.2, "y": 4.3, "width": 0.7, "height": 0.4, "label": "接入交换机"},
    {"id": "branch2_pc1", "type": "pc", "x": 9.8, "y": 4.8, "width": 0.4, "height": 0.3, "label": "办公 PC"},
    {"id": "branch2_pc2", "type": "pc", "x": 10.6, "y": 4.8, "width": 0.4, "height": 0.3, "label": "办公 PC"}
