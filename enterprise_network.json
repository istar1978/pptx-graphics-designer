      "x": 4.5,
      "y": 0.8,
      "width": 4.5,
      "height": 4.5
    },
    {
      "id": "branch1_zone",
      "type": "office",
      "title": "分支机构 1",
      "x": 9.5,
      "y": 0.8,
      "width": 3.5,
      "height": 2.0
    },
    {
      "id": "branch2_zone",
      "type": "office",
      "title": "分支机构 2",
      "x": 9.5,
      "y": 3.2,
      "width": 3.5,
      "height": 2.0
    }
  ],
  "devices": [
