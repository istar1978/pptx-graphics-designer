    {"id": "cloud_app", "type": "server", "x": 2.3, "y": 2.3, "width": 0.6, "height": 0.4, "label": "云服务"},
    
    {"id": "hq_router", "type": "router", "x": 5.5, "y": 1.2, "width": 0.8, "height": 0.6, "label": "核心路由器"},
    {"id": "hq_fw1", "type": "firewall", "x": 4.8, "y": 2.2, "width": 0.6, "height": 0.6, "label": "防火墙"},
    {"id": "hq_fw2", "type": "firewall", "x": 6.2, "y": 2.2, "width": 0.6, "height": 0.6, "label": "防火墙"},
    {"id": "hq_core_sw", "type": "switch", "x": 5.5, "y": 3.2, "width": 0.8, "height": 0.5, "label": "核心交换机"},
    
